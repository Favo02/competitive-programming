HEADS A

START * FIND_D * R

FIND_D = FIND_D * D
FIND_D _ D_TO_U * R
FIND_D | TO_DELETE * U

D_TO_U _ FIND_U * U
U_TO_D _ FIND_D * D

FIND_U = FIND_U * U
FIND_U _ U_TO_D * R
FIND_U | TO_DELETE * U

TO_DELETE ! TO_DELETE | U
TO_DELETE _ DELETE * D

DELETE ! R_DELETE | R
R_DELETE ! R_DELETE _ R
R_DELETE _ L_DELETE _ L
L_DELETE _ L_DELETE _ L
L_DELETE | DELETE * D
DELETE _ STOP * S
